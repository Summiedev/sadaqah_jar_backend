APP_NAME=Sadaqah Jar API
ENV=development

# Local PostgreSQL example
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sadaqah

# Local Redis example (or replace with Upstash rediss://...)
REDIS_URL=redis://127.0.0.1:6379/0

# Use a long random string (32+ chars)
JWT_SECRET=change_me_to_a_strong_secret_at_least_32_characters

ACCESS_TOKEN_EXPIRE_MINUTES=15

# Comma-separated list of allowed frontend origins
# For Flutter web local run:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For hosted web app:
# CORS_ORIGINS=https://your-frontend-domain.com
CORS_ORIGINS=

# SMTP for transactional emails (verification, password reset)
# Leave SMTP_HOST empty to skip real sends (messages are logged)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@sadaqahjar.app

# Public URL for building email links (no trailing slash)
APP_URL=http://localhost:8000
                                